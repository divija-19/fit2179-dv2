{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "Connected dot plot comparing ticket-buyer age shares pre-COVID (2018-19) vs post-COVID (2022-23). Click legend to highlight. Sources: Live Performance Australia; Creative Australia Soundcheck 2024.",
  "width": "container",
  "height": 280,
  "config": {
    "background": "transparent",
    "view": { "stroke": "transparent" },
    "axis": {
      "domainColor": "#282822", "gridColor": "#1e1e18", "tickColor": "#282822",
      "labelColor": "#7a7570", "titleColor": "#7a7570",
      "labelFont": "Inter, sans-serif", "titleFont": "Space Mono, monospace",
      "labelFontSize": 13, "titleFontSize": 11
    },
    "legend": {
      "labelColor": "#7a7570", "titleColor": "#7a7570",
      "labelFont": "Inter, sans-serif", "titleFont": "Space Mono, monospace",
      "labelFontSize": 12, "titleFontSize": 11
    }
  },
  "data": { "url": "data/age_demographics.json" },
  "params": [{
    "name": "period_hl",
    "select": { "type": "point", "fields": ["period"] },
    "bind": "legend"
  }],
  "layer": [
    {
      "mark": { "type": "line", "color": "#3a3a32", "strokeWidth": 2 },
      "encoding": {
        "x": { "field": "age_group", "type": "nominal", "axis": { "title": "Age Group", "labelFontSize": 13 } },
        "y": { "field": "pct", "type": "quantitative", "axis": { "title": "Share of Ticket Buyers (%)" } },
        "detail": { "field": "age_group", "type": "nominal" }
      }
    },
    {
      "mark": { "type": "point", "filled": true, "size": 130 },
      "encoding": {
        "x": { "field": "age_group", "type": "nominal" },
        "y": { "field": "pct", "type": "quantitative" },
        "color": {
          "field": "period", "type": "nominal",
          "scale": {
            "domain": ["Pre-COVID (2018–19)", "Post-COVID (2022–23)"],
            "range": ["#9B5DE5", "#FFD166"]
          },
          "legend": { "title": "Period — click to highlight", "orient": "top-right" }
        },
        "opacity": { "condition": { "param": "period_hl", "value": 1 }, "value": 0.1 },
        "tooltip": [
          { "field": "age_group", "title": "Age Group" },
          { "field": "period", "title": "Period" },
          { "field": "pct", "title": "Share (%)", "format": ".0f" }
        ]
      }
    },
    {
      "data": { "values": [{ "age_group": "18–24", "pct": 32, "lbl": "−12pp" }] },
      "mark": { "type": "text", "align": "center", "dy": -18, "color": "#EF233C", "font": "Space Mono, monospace", "fontSize": 11, "fontWeight": "bold" },
      "encoding": {
        "x": { "field": "age_group", "type": "nominal" },
        "y": { "field": "pct", "type": "quantitative" },
        "text": { "field": "lbl" }
      }
    }
  ]
}
