{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "Stacked horizontal bar showing severe and major impact of challenges on festival organisers. Slider filters by minimum severe impact. Source: Creative Australia Soundcheck 2024.",
  "width": "container",
  "height": 310,
  "config": {
    "background": "transparent",
    "view": { "stroke": "transparent" },
    "axis": {
      "domainColor": "#282822",
      "gridColor": "#1e1e18",
      "tickColor": "#282822",
      "labelColor": "#7a7570",
      "titleColor": "#7a7570",
      "labelFont": "Trebuchet MS",
      "titleFont": "Trebuchet MS",
      "labelFontSize": 11,
      "titleFontSize": 11
    },
    "legend": {
      "labelColor": "#7a7570",
      "titleColor": "#7a7570",
      "labelFont": "Trebuchet MS",
      "titleFont": "Trebuchet MS",
      "labelFontSize": 12,
      "titleFontSize": 11
    }
  },
  "data": { "url": "data/challenges_stacked.json" },
  "params": [
    {
      "name": "min_sev",
      "value": 0,
      "bind": {
        "input": "range",
        "min": 0,
        "max": 50,
        "step": 1,
        "name": "Minimum Severe Impact %: "
      }
    }
  ],
  "transform": [
    { "filter": "datum.severe_pct >= min_sev" }
  ],
  "mark": {
    "type": "bar",
    "cornerRadiusTopRight": 3,
    "cornerRadiusBottomRight": 3
  },
  "encoding": {
    "y": {
      "field": "challenge",
      "type": "nominal",
      "sort": { "field": "severe_pct", "order": "descending" },
      "axis": { "title": null, "labelFontSize": 11, "labelLimit": 240 }
    },
    "x": {
      "field": "pct",
      "type": "quantitative",
      "stack": null,
      "axis": { "title": "Percentage of festival organisers impacted (%)" },
      "scale": { "domain": [0, 50] }
    },
    "color": {
      "field": "impact_type",
      "type": "nominal",
      "scale": {
        "domain": ["Severe impact", "Major impact"],
        "range": ["#EF233C", "#5a1e28"]
      },
      "legend": { "title": "Impact Level", "orient": "bottom-right" }
    },
    "detail": { "field": "impact_type" },
    "order": { "field": "impact_type", "sort": "descending" },
    "tooltip": [
      { "field": "challenge", "title": "Challenge" },
      { "field": "impact_type", "title": "Impact Level" },
      { "field": "pct", "title": "Organisers Impacted (%)", "format": ".0f" }
    ]
  }
}
