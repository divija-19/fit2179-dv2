{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "Stacked horizontal bar showing severe and major impact of challenges on festival organisers. Slider filters by minimum severe impact. Source: Creative Australia Soundcheck 2024.",
  "width": "container",
  "height": 310,
  "data": {
    "values": [
      { "challenge": "Rising operational costs", "severe_pct": 47, "major_pct": 31, "impact_type": "Severe impact", "pct": 47 },
      { "challenge": "Rising operational costs", "severe_pct": 47, "major_pct": 31, "impact_type": "Major impact", "pct": 31 },
      { "challenge": "Lack of funding & grants", "severe_pct": 39, "major_pct": 28, "impact_type": "Severe impact", "pct": 39 },
      { "challenge": "Lack of funding & grants", "severe_pct": 39, "major_pct": 28, "impact_type": "Major impact", "pct": 28 },
      { "challenge": "Insurance costs", "severe_pct": 31, "major_pct": 24, "impact_type": "Severe impact", "pct": 31 },
      { "challenge": "Insurance costs", "severe_pct": 31, "major_pct": 24, "impact_type": "Major impact", "pct": 24 },
      { "challenge": "Extreme weather events", "severe_pct": 22, "major_pct": 29, "impact_type": "Severe impact", "pct": 22 },
      { "challenge": "Extreme weather events", "severe_pct": 22, "major_pct": 29, "impact_type": "Major impact", "pct": 29 },
      { "challenge": "Late ticket buying", "severe_pct": 20, "major_pct": 35, "impact_type": "Severe impact", "pct": 20 },
      { "challenge": "Late ticket buying", "severe_pct": 20, "major_pct": 35, "impact_type": "Major impact", "pct": 35 },
      { "challenge": "Police & security costs", "severe_pct": 18, "major_pct": 26, "impact_type": "Severe impact", "pct": 18 },
      { "challenge": "Police & security costs", "severe_pct": 18, "major_pct": 26, "impact_type": "Major impact", "pct": 26 },
      { "challenge": "Council regulations", "severe_pct": 15, "major_pct": 30, "impact_type": "Severe impact", "pct": 15 },
      { "challenge": "Council regulations", "severe_pct": 15, "major_pct": 30, "impact_type": "Major impact", "pct": 30 }
    ]
  },
  "params": [
    {
      "name": "min_sev",
      "value": 0,
      "bind": {
        "input": "range",
        "min": 0,
        "max": 50,
        "step": 1,
        "name": "Minimum Severe Impact %: "
      }
    }
  ],
  "transform": [
    { "filter": "datum.severe_pct >= min_sev" }
  ],
  "mark": {
    "type": "bar",
    "cornerRadiusTopRight": 3,
    "cornerRadiusBottomRight": 3
  },
  "encoding": {
    "y": {
      "field": "challenge",
      "type": "nominal",
      "sort": { "field": "severe_pct", "order": "descending" },
      "axis": { "title": null, "labelFontSize": 11, "labelLimit": 240 }
    },
    "x": {
      "field": "pct",
      "type": "quantitative",
      "stack": null,
      "scale": { "domain": [0, 50] },
      "axis": { "title": "Percentage of festival organisers impacted (%)" }
    },
    "color": {
      "field": "impact_type",
      "type": "nominal",
      "scale": {
        "domain": ["Severe impact", "Major impact"],
        "range": ["#EF233C", "#5a1e28"]
      },
      "legend": { "title": "Impact Level", "orient": "bottom-right" }
    },
    "detail": { "field": "impact_type" },
    "order": { "field": "impact_type", "sort": "descending" },
    "tooltip": [
      { "field": "challenge", "title": "Challenge" },
      { "field": "impact_type", "title": "Impact Level" },
      { "field": "pct", "title": "Organisers Impacted (%)", "format": ".0f" }
    ]
  }
}
