{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "Stacked area chart: contemporary music revenue vs all other categories 2004-2024. Shows the growing dominance of big stadium tours. Source: Live Performance Australia.",
  "width": "container",
  "height": 270,
  "config": {
    "background": "transparent",
    "view": { "stroke": "transparent" },
    "axis": {
      "domainColor": "#282822", "gridColor": "#1e1e18", "tickColor": "#282822",
      "labelColor": "#7a7570", "titleColor": "#7a7570",
      "labelFont": "Inter, sans-serif", "titleFont": "Space Mono, monospace",
      "labelFontSize": 12, "titleFontSize": 11
    },
    "legend": {
      "labelColor": "#7a7570", "titleColor": "#7a7570",
      "labelFont": "Inter, sans-serif", "titleFont": "Space Mono, monospace",
      "labelFontSize": 12, "titleFontSize": 11
    }
  },
  "data": { "url": "../data/lpa_annual.json" },
  "transform": [
    { "fold": ["contemporary_revenue_b", "other_revenue_b"], "as": ["category_key", "value"] },
    {
      "calculate": "datum.category_key === 'contemporary_revenue_b' ? 'Contemporary Music' : 'All Other Categories'",
      "as": "category"
    }
  ],
  "mark": { "type": "area", "interpolate": "monotone" },
  "encoding": {
    "x": { "field": "year", "type": "quantitative", "axis": { "format": "d", "title": "Year", "tickCount": 11 } },
    "y": { "field": "value", "type": "quantitative", "stack": "zero", "axis": { "title": "Revenue (AUD Billion)", "format": "$,.1f" } },
    "color": {
      "field": "category", "type": "nominal",
      "scale": {
        "domain": ["Contemporary Music", "All Other Categories"],
        "range": ["#FFD166", "#2a2a22"]
      },
      "legend": { "title": "Category", "orient": "top-right" }
    },
    "opacity": {
      "field": "category", "type": "nominal",
      "scale": { "domain": ["Contemporary Music", "All Other Categories"], "range": [0.88, 0.55] },
      "legend": null
    },
    "tooltip": [
      { "field": "year", "title": "Year", "format": "d" },
      { "field": "category", "title": "Category" },
      { "field": "value", "title": "Revenue ($B)", "format": "$.2f" }
    ]
  }
}
