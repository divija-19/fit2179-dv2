{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "Year-on-year percentage change in live music revenue 2005-2024. Source: Live Performance Australia.",
  "width": "container",
  "height": 240,
  "config": {
    "background": "transparent",
    "view": { "stroke": "transparent" },
    "axis": {
      "domainColor": "#282822", "gridColor": "#1e1e18", "tickColor": "#282822",
      "labelColor": "#7a7570", "titleColor": "#7a7570",
      "labelFont": "Inter, sans-serif", "titleFont": "Space Mono, monospace",
      "labelFontSize": 12, "titleFontSize": 11
    }
  },
  "data": { "url": "data/lpa_annual.json" },
  "transform": [ { "filter": "datum.year > 2004" } ],
  "layer": [
    {
      "mark": {
        "type": "bar",
        "cornerRadiusTopRight": 2, "cornerRadiusBottomRight": 2,
        "cornerRadiusTopLeft": 2, "cornerRadiusBottomLeft": 2
      },
      "encoding": {
        "x": {
          "field": "year", "type": "ordinal",
          "axis": { "title": null, "labelAngle": -45, "labelFontSize": 11 }
        },
        "y": {
          "field": "rev_pct_change", "type": "quantitative",
          "axis": { "title": "Revenue change from prior year (%)", "grid": true },
          "scale": { "domain": [-85, 70] }
        },
        "color": {
          "condition": { "test": "datum.rev_pct_change < 0", "value": "#EF233C" },
          "value": "#06D6A0"
        },
        "tooltip": [
          { "field": "year", "title": "Year" },
          { "field": "rev_pct_change", "title": "Change (%)", "format": ".1f" },
          { "field": "revenue_b", "title": "Revenue ($B)", "format": "$.2f" }
        ]
      }
    },
    {
      "mark": { "type": "rule", "color": "#383830", "strokeWidth": 1, "strokeDash": [4, 4] },
      "encoding": { "y": { "datum": 0, "type": "quantitative" } }
    },
    {
      "data": { "values": [{ "year": "2020", "v": -76.9, "lbl": "−77%" }] },
      "mark": {
        "type": "text", "align": "center", "dy": -13,
        "color": "#EF233C", "font": "Space Mono, monospace", "fontSize": 10, "fontWeight": "bold"
      },
      "encoding": {
        "x": { "field": "year", "type": "ordinal" },
        "y": { "field": "v", "type": "quantitative" },
        "text": { "field": "lbl" }
      }
    },
    {
      "data": { "values": [{ "year": "2023", "v": 61.5, "lbl": "+62%" }] },
      "mark": {
        "type": "text", "align": "center", "dy": -13,
        "color": "#06D6A0", "font": "Space Mono, monospace", "fontSize": 10, "fontWeight": "bold"
      },
      "encoding": {
        "x": { "field": "year", "type": "ordinal" },
        "y": { "field": "v", "type": "quantitative" },
        "text": { "field": "lbl" }
      }
    }
  ]
}
