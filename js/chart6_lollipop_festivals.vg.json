{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "Lollipop chart: number of festivals per state, dot colour shows revenue per festival in $M. Source: Creative Australia Soundcheck 2024.",
  "width": "container",
  "height": 280,
  "config": {
    "background": "transparent",
    "view": { "stroke": "transparent" },
    "axis": {
      "domainColor": "#282822", "gridColor": "#1e1e18", "tickColor": "#282822",
      "labelColor": "#7a7570", "titleColor": "#7a7570",
      "labelFont": "Inter, sans-serif", "titleFont": "Space Mono, monospace",
      "labelFontSize": 13, "titleFontSize": 11
    },
    "legend": {
      "labelColor": "#7a7570", "titleColor": "#7a7570",
      "labelFont": "Inter, sans-serif", "titleFont": "Space Mono, monospace",
      "labelFontSize": 11, "titleFontSize": 11
    }
  },
  "data": { "url": "../data/state_data.json" },
  "layer": [
    {
      "mark": { "type": "rule", "strokeWidth": 2 },
      "encoding": {
        "y": {
          "field": "state_abbr", "type": "nominal",
          "sort": "-x",
          "axis": { "title": null, "labelFontSize": 13 }
        },
        "x": {
          "field": "festivals", "type": "quantitative",
          "axis": { "title": "Number of Festivals (2022–23)" },
          "scale": { "domain": [0, 180] }
        },
        "x2": { "value": 0 },
        "color": {
          "field": "state_abbr", "type": "nominal",
          "scale": { "scheme": "tableau10" },
          "legend": null
        }
      }
    },
    {
      "mark": { "type": "point", "filled": true, "size": 140 },
      "encoding": {
        "y": { "field": "state_abbr", "type": "nominal", "sort": "-x" },
        "x": { "field": "festivals", "type": "quantitative" },
        "color": {
          "field": "rev_per_festival", "type": "quantitative",
          "scale": { "scheme": "reds", "domain": [0, 12] },
          "legend": {
            "title": "Revenue per Festival ($M)",
            "orient": "bottom-right",
            "labelFormat": ".1f"
          }
        },
        "tooltip": [
          { "field": "state", "title": "State" },
          { "field": "festivals", "title": "Festivals" },
          { "field": "rev_per_festival", "title": "Revenue per Festival ($M)", "format": ".2f" },
          { "field": "revenue_b", "title": "Total Revenue ($B)", "format": "$.3f" }
        ]
      }
    }
  ]
}
